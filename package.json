{
  "name": "solice-desktop-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "SOLICE, a loyal Electron desktop AI companion.",
  "productName": "SOLICE Desktop Assistant",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n NEXT,ELECTRON -c cyan,blue \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:main": "wait-on http://127.0.0.1:3000 && node scripts/run-electron.js . --dev",
    "build": "next build",
    "start": "node scripts/run-electron.js .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron": "^42.1.0",
    "electron-store": "^11.0.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "node-audiorecorder": "^3.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "screenshot-desktop": "^1.15.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10"
  }
}
